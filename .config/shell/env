# xdg
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

# homebrew
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
if command -v brew >/dev/null 2>&1; then
  export HOMEBREW_NO_AUTO_UPDATE=1
  export HOMEBREW_NO_ANALYTICS=1
fi

# asdf — shims for tools in .tool-versions (neovim, node, python, …)
if command -v brew >/dev/null 2>&1; then
  _asdf_root="$(brew --prefix asdf 2>/dev/null)"
  if [ -n "$_asdf_root" ] && [ -f "$_asdf_root/libexec/asdf.sh" ]; then
    . "$_asdf_root/libexec/asdf.sh"
  fi
  unset _asdf_root
fi

# tools
export EDITOR="nvim"
export VISUAL="$EDITOR"
export GIT_EDITOR="$EDITOR"
export PAGER="less"
export LESS="-R --quit-if-one-screen"
export LESSHISTFILE="${XDG_DATA_HOME}/less/history"

# history
export HISTSIZE=50000
export SAVEHIST="$HISTSIZE"

# locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# path
case ":$PATH:" in
  *:"$HOME/.local/bin":*) ;;
  *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

# JetBrains Toolbox
_toolbox="$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
case ":$PATH:" in
  *:"$_toolbox":*) ;;
  *) export PATH="$PATH:$_toolbox" ;;
esac
unset _toolbox
