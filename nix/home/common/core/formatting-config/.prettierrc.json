{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": false,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.json", "*.json5"],
      "options": {
        "parser": "json",
        "tabWidth": 2,
        "semi": true,
        "singleQuote": false,
        "trailingComma": "none",
        "bracketSpacing": true
      }
    },
    {
      "files": ["*.html", "*.vue"],
      "options": {
        "htmlWhitespaceSensitivity": "css",
        "singleAttributePerLine": false
      }
    },
    {
      "files": ["*.md", "*.markdown"],
      "options": {
        "proseWrap": "always",
        "printWidth": 80
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "singleQuote": false,
        "bracketSpacing": true
      }
    },
    {
      "files": ["*.css", "*.scss", "*.less"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}