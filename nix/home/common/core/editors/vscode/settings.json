{
  // Window and Interface
  "window.zoomLevel": 2,
  "window.commandCenter": false,
  "window.menuBarVisibility": "compact",
  "window.restoreWindows": "none",
  "window.density.editorTabHeight": "compact",
  "workbench.editor.showTabs": "multiple",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.tree.indent": 20,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.editor.enablePreview": false,
  "material-icon-theme.hidesExplorerArrows": true,

  // Editor - Appearance
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 15,
  "editor.lineHeight": 20,
  "editor.minimap.enabled": false,
  "editor.lineNumbers": "relative",
  "editor.renderWhitespace": "trailing",

  // Editor - Behavior
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "off",
  "editor.suggest.insertMode": "replace",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.linkedEditing": true,

  // Explorer
  "explorer.autoReveal": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,

  // Files
  "files.autoSave": "off",
  "files.defaultLanguage": "markdown",

  // Git
  "git.confirmSync": false,

  // Extensions - GitLens
  "gitlens.hovers.currentLine.over": "line",

  // Extensions - Visual Indentation
  "indentRainbow.colors": [
    "rgba(255,255,64,0.02)",
    "rgba(127,255,127,0.02)",
    "rgba(255,127,255,0.02)",
    "rgba(79,236,236,0.02)"
  ],
  "RainbowBrackets.depreciation-notice": false,

  // Extensions - Emmet
  "emmet.triggerExpansionOnTab": true,

  // VSCodeVim - setting
  "vim.useSystemClipboard": true,
  "vim.timeoutlen": 300,
  "vim.hlsearch": true,

  // Which Key
  "whichkey.useFullWidthCharacters": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    }
  ],
  "whichkey.bindings": [
    {
      "key": "/",
      "name": "[/] Fuzzy search in current editor",
      "type": "command",
      "command": "fuzzySearch.activeTextEditor"
    },
    {
      "key": "a",
      "name": "[A]dd editor to harpoon",
      "type": "command",
      "command": "vscode-harpoon.addEditor"
    },
    {
      "key": "e",
      "name": "[E]dit harpoon editors",
      "type": "command",
      "command": "vscode-harpoon.editEditors"
    },
    {
      "key": "q",
      "name": "[Q]uit",
      "type": "bindings",
      "bindings": [
        {
          "key": "w",
          "name": "[Q]uit and [W]rite (Save & Close Window)",
          "type": "commands",
          "commands": ["workbench.action.files.save", "workbench.action.closeActiveEditor"]
        },
        {
          "key": "q",
          "name": "[Q]uit without saving (Close Window)",
          "type": "command",
          "command": "workbench.action.closeActiveEditor"
        }
      ]
    },
    {
      "key": "w",
      "name": "[W]rite ",
      "type": "command",
      "command": "workbench.action.files.save"
    },
    {
      "key": "s",
      "name": "[S]earch",
      "type": "bindings",
      "bindings": [
        {
          "key": "p",
          "name": "[S]earch Command [P]alette",
          "type": "command",
          "command": "workbench.action.showCommands"
        },
        {
          "key": "e",
          "name": "[S]earch [E]xtensions",
          "type": "command",
          "command": "workbench.view.extensions"
        }
      ]
    },
    {
      "key": "f",
      "name": "[F]ile",
      "type": "bindings",
      "bindings": [
        {
          "key": "f",
          "name": "[S]earch [F]iles",
          "type": "command",
          "command": "workbench.action.quickOpen"
        },
        {
          "key": ".",
          "name": "[S]earch Recent Files",
          "type": "command",
          "command": "workbench.action.openRecent"
        },
        {
          "key": "t",
          "name": "Open File [T]ree",
          "type": "command",
          "command": "workbench.view.explorer"
        }
      ]
    },
    {
      "key": "c",
      "name": "[C]ode",
      "type": "bindings",
      "bindings": [
        {
          "key": "f",
          "name": "[F]format Document",
          "type": "command",
          "command": "editor.action.formatDocument"
        }
      ]
    }
  ],

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },

  // Prettier Configuration
  "prettier.requireConfig": true,
  "prettier.configPath": "~/.dotfiles/nix/home/programs/tools/config/formatting-config/.prettierrc.json",

  // ESLint Configuration
  "eslint.enable": true,
  "eslint.options": {
    "configFile": "~/.dotfiles/nix/home/programs/tools/config/linting-config/.eslintrc.json"
  },
  "eslint.validate": ["javascript", "typescript", "html", "vue", "json", "markdown", "yaml"],

  // Stylelint Configuration
  "stylelint.enable": true,
  "stylelint.configFile": "~/.dotfiles/nix/home/programs/tools/config/stylelint-config/.stylelintrc.json",
  "stylelint.validate": ["css", "scss", "less", "postcss"]
}
